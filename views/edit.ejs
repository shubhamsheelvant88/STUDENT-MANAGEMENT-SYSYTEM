<% layout("/layouts/boilerplate") %>
<div class="edit">
    <h4>Edit student OF ID : <%= student.id %></h4>
    <br>
    <form action="/students/<%= student.id %>/edit?_method=PATCH" method="POST">
    <div class="container">
        <div class="row">
            <div >
        <label for="name" class="form-label">NAME : </label>
        <input type="text" id="name" name="name" value="<%= student.name %>" class="form-control">
        <br>
        <br>
        <label for="email" class="form-label">EMAIL : </label>
        <input type="email" id="email" name="email" value="<%= student.email %>" class="form-control">
        <br>
        <br>
        <label for="dept" class="form-label">DEPARTMENT : </label>
        <input type="text" id="dept" name="department" value="<%= student.department %>" class="form-control">
        <br>
        <br>
        <label for="sem" class="form-label">SEMESTER : </label>
        <input type="number" id="sem" name="semester" value="<%= student.semester %>" class="form-control">
        <br>
        <br>
        <label for="ph" class="form-label">PHONE NO : </label>
        <input type="text" id="ph" name="phone" value="<%= student.phone %>" class="form-control">
        <br>
        <br>
        <button type="submit" class="btn btn-success">Update</button>
        </div>
    </div>
    </div>
    </form>
</div>