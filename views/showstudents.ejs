<style>
    table {
        width: 100%;
    }
    table ,td, th {
        border : 1px solid black;
    }
    .search-info {
        display : flex;
        margin: 15px;
    }
    #btn-search {
        margin-right : 4px;
    }
</style>

<% layout("/layouts/boilerplate") %>
    <div class="search-info">
        <form action="/students" method="GET">
            <input type="text" id="searchInput" name="search" value="<%= search %>"><!-- search="shubham"  -->
            <button type="submit" id="btn-search" class="btn btn-secondary">Search</button>
            <% if (search) { %>
            <a href="/students"><button type="button" class="btn btn-light">Clear Search</button></a>
            <% } %>
        </form>
    <form action="/students/add">
        <button class="btn btn-warning">Create</button>
        </form>    
    </div>
    
    <table>
        <tr>
            <th>ID</th>
            <th>NAME</th>
            <th>EMAIL</th>
            <th>DEPARTMENT</th>
            <th>SEMESTER</th>
            <th>PHONE NO</th>
            <th>CREATED AT</th>
        </tr>

        <% for(student of students) { %>
            <tr>
                <td><%= student.id %></td>
                <td><%= student.name %></td>
                <td><%= student.email %></td>
                <td><%= student.department %></td>
                <td><%= student.semester %></td>
                <td><%= student.phone %></td>
                <td><%= student.created_at %></td>
                <td>
                    <br>
                    <a href="/students/<%= student.id %>">
                        <button type="button" class="btn btn-info">Show</button>
                    </a>
                    <br>
                    <br>
                     <form action="/students/<%= student.id %>/edit">
                        <button class="btn btn-danger">Edit</button>
                    </form>
                    <br> 
                    <form action="/students/<%= student.id %>?_method=DELETE" method="POST"> 
                        <button type="submit" class="btn btn-primary">Delete</button>
                    </form>
                </td>
            </tr>
        <%}%>
    </table>
    <% if (students.length === 0) { %>
        <p>No students found.</p>
    <% } %>
    <br>